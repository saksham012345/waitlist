# ─── Server ──────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Couchbase ───────────────────────────────────────────────────
COUCHBASE_URI=couchbases://cb.xxxxxxxxxxxxxxxx.cloud.couchbase.com
COUCHBASE_USERNAME=admin
COUCHBASE_PASSWORD=your_password_here
COUCHBASE_BUCKET=trektribe

# ─── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins for production
# Example: https://trektribe.vercel.app,https://trektribe.in
ALLOWED_ORIGINS=
